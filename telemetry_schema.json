{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TruckTelemetryPayload",
  "description": "Schema for truck telemetry data generated by TTGenerator",
  "type": "object",
  "required": [
    "event_ts",
    "customer_id",
    "vehicle_id",
    "device_id",
    "latitude",
    "longitude",
    "ignition_status"
  ],
  "properties": {
    "event_ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the event"
    },
    "customer_id": {
      "type": "string",
      "description": "Unique identifier for the customer"
    },
    "vehicle_id": {
      "type": "string",
      "description": "Unique identifier for the vehicle (e.g., V000001)"
    },
    "device_id": {
      "type": "string",
      "description": "Unique identifier for the telematics device"
    },
    "latitude": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "description": "GPS latitude in decimal degrees"
    },
    "longitude": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "description": "GPS longitude in decimal degrees"
    },
    "altitude_m": {
      "type": "number",
      "description": "Altitude in meters"
    },
    "gps_speed_kph": {
      "type": "number",
      "minimum": 0,
      "description": "Speed reported by GPS in km/h"
    },
    "heading_deg": {
      "type": "number",
      "minimum": 0,
      "maximum": 360,
      "description": "Vehicle heading in degrees (0-360)"
    },
    "hdop": {
      "type": "number",
      "description": "Horizontal Dilution of Precision"
    },
    "satellite_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of satellites used for GPS fix"
    },
    "fix_quality": {
      "type": "integer",
      "description": "GPS fix quality indicator"
    },
    "accel_x_g": { "type": "number" },
    "accel_y_g": { "type": "number" },
    "accel_z_g": { "type": "number" },
    "gyro_x_dps": { "type": "number" },
    "gyro_y_dps": { "type": "number" },
    "gyro_z_dps": { "type": "number" },
    "vehicle_speed_kph": {
      "type": "number",
      "minimum": 0,
      "description": "Speed from vehicle bus (J1939) in km/h"
    },
    "engine_rpm": {
      "type": "number",
      "minimum": 0
    },
    "accelerator_pedal_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "engine_load_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "engine_torque_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "fuel_rate_lph": {
      "type": "number",
      "description": "Fuel consumption rate in Liters Per Hour"
    },
    "total_fuel_used_l": {
      "type": "number"
    },
    "fuel_level_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "coolant_temp_c": { "type": "number" },
    "oil_temp_c": { "type": "number" },
    "oil_pressure_kpa": { "type": "number" },
    "intake_manifold_pressure_kpa": { "type": "number" },
    "battery_voltage_v": { "type": "number" },
    "engine_hours": { "type": "number" },
    "odometer_km": { "type": "integer" },
    "gear_selected": { "type": "integer" },
    "brake_switch": { "type": "integer", "enum": [0, 1, 255] },
    "clutch_switch": { "type": "integer", "enum": [0, 1, 255] },
    "pto_status": { "type": "integer" },
    "active_dtc_count": { "type": "integer" },
    "ignition_status": {
      "type": "integer",
      "enum": [0, 1],
      "description": "0: OFF, 1: ON"
    },
    "external_power_v": { "type": "number" },
    "backup_battery_v": { "type": "number" },
    "device_temp_c": { "type": "number" },
    "gsm_signal_dbm": { "type": "integer" },
    "network_type": {
      "type": "string",
      "description": "e.g., 4G, 5G, LTE"
    },
    "gnss_fix_status": { "type": "integer" },
    "can_bus_health": { "type": "integer" },
    "storage_queue_depth": { "type": "integer" },
    "tamper_alert": {
      "type": "integer",
      "enum": [0, 1]
    }
  }
}
